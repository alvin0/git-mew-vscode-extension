{
  "name": "git-mew",
  "displayName": "Git Mew",
  "description": "Your AI kitty for Git chaos - Generate intelligent commit messages using AI",
  "version": "0.5.7",
  "icon": "resources/images/logo.png",
  "publisher": "GitMew",
  "engines": {
    "vscode": "^1.75.1"
  },
  "categories": [
    "SCM Providers",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "llm",
    "openai",
    "claude",
    "gemini",
    "ollama",
    "openai-compatible",
    "commit message"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alvin0/git-mew-vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/alvin0/git-mew-vscode-extension/issues"
  },
  "homepage": "https://github.com/alvin0/git-mew-vscode-extension#readme",
  "activationEvents": [
    "onStartupFinished",
    "onView:git-mew-commands",
    "onCommand:git-mew.generate-commit",
    "onCommand:git-mew.cancel-generate",
    "onCommand:git-mew.setupModelGenerateCommit",
    "onCommand:git-mew.manage-api-keys",
    "onCommand:git-mew.review-merge",
    "onCommand:git-mew.review-staged-changes",
    "onCommand:git-mew.review-merged-branch",
    "onCommand:git-mew.showCommands",
    "onCommand:git-mew.publish",
    "onCommand:git-mew.manage-global-config",
    "onCommand:git-mew.show-review-panel",
    "onCommand:gitmew.clearReviewMemory"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-mew-sidebar",
          "title": "Git Mew",
          "icon": "resources/images/logo-white-no-background.png"
        }
      ]
    },
    "views": {
      "git-mew-sidebar": [
        {
          "id": "git-mew-commands",
          "name": "Source Control",
          "type": "webview",
          "icon": "resources/images/logo-white-no-background.png",
          "retainContextWhenHidden": true
        },
        {
          "id": "gitmew-graph",
          "name": "Graph",
          "type": "webview",
          "retainContextWhenHidden": true,
          "visibility": "collapsed",
          "icon": "$(git-commit)"
        },
        {
          "id": "gitmew-code-review",
          "name": "Code Review",
          "icon": "$(eye)",
          "visibility": "collapsed"
        },
        {
          "id": "gitmew-settings",
          "name": "Settings",
          "icon": "$(gear)",
          "visibility": "collapsed"
        },
        {
          "id": "gitmew-global-config",
          "name": "Global Config (~/.gitmew)",
          "icon": "$(folder)",
          "visibility": "collapsed"
        },
        {
          "id": "gitmew-histories",
          "name": "Histories",
          "icon": "$(history)",
          "visibility": "collapsed"
        }
      ]
    },
    "commands": [
      {
        "command": "git-mew.generate-commit",
        "title": "git-mew: Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "git-mew.cancel-generate",
        "title": "git-mew: Cancel Generation",
        "icon": "$(debug-pause)"
      },
      {
        "command": "git-mew.setupModelGenerateCommit",
        "title": "git-mew: Setup Model Generate Commit"
      },
      {
        "command": "git-mew.manage-api-keys",
        "title": "git-mew: Manage API Keys"
      },
      {
        "command": "git-mew.review-merge",
        "title": "git-mew: Review Merge",
        "icon": "$(git-merge)"
      },
      {
        "command": "git-mew.review-staged-changes",
        "title": "git-mew: Review Staged Changes",
        "icon": "$(eye)"
      },
      {
        "command": "git-mew.review-merged-branch",
        "title": "git-mew: Review Merged Branch",
        "icon": "$(history)"
      },
      {
        "command": "git-mew.review-selected-commits",
        "title": "git-mew: Review Selected Commits",
        "icon": "$(checklist)"
      },
      {
        "command": "git-mew.showCommands",
        "title": "git-mew: Show Commands"
      },
      {
        "command": "git-mew.publish",
        "title": "git-mew: Publish Files"
      },
      {
        "command": "git-mew.manage-global-config",
        "title": "git-mew: Manage Global Config (~/.gitmew)"
      },
      {
        "command": "git-mew.global-config.create",
        "title": "Create",
        "icon": "$(add)"
      },
      {
        "command": "git-mew.global-config.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "git-mew.global-config.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "git-mew.show-review-panel",
        "title": "git-mew: Show Review Panel"
      },
      {
        "command": "gitmew.clearReviewMemory",
        "title": "Git Mew: Clear Review Memory"
      },
      {
        "command": "git-mew.send-feedback",
        "title": "git-mew: Send Feedback",
        "icon": "$(feedback)"
      },
      {
        "command": "git-mew.history.preview",
        "title": "Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "git-mew.history.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "git-mew.history.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "git-mew.history.open-in-editor",
        "title": "Open in Editor",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "git-mew.global-config.refresh",
          "when": "view == gitmew-global-config",
          "group": "navigation"
        },
        {
          "command": "git-mew.history.refresh",
          "when": "view == gitmew-histories",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "git-mew.global-config.create",
          "when": "view == gitmew-global-config && viewItem == gitmew-file-missing",
          "group": "inline"
        },
        {
          "command": "git-mew.global-config.delete",
          "when": "view == gitmew-global-config && viewItem == gitmew-file-exists",
          "group": "inline"
        },
        {
          "command": "git-mew.history.open-in-editor",
          "when": "view == gitmew-histories && viewItem == gitmew-history-file",
          "group": "inline@1"
        },
        {
          "command": "git-mew.history.delete",
          "when": "view == gitmew-histories && viewItem == gitmew-history-file",
          "group": "inline@2"
        }
      ],
      "scm/title": [
        {
          "command": "git-mew.generate-commit",
          "when": "scmProvider == git && !git-mew.isGenerating",
          "group": "navigation"
        },
        {
          "command": "git-mew.cancel-generate",
          "when": "scmProvider == git && git-mew.isGenerating",
          "group": "navigation"
        },
        {
          "command": "git-mew.review-merge",
          "when": "scmProvider == git",
          "group": "navigation"
        },
        {
          "command": "git-mew.review-staged-changes",
          "when": "scmProvider == git",
          "group": "navigation"
        },
        {
          "command": "git-mew.review-merged-branch",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "git-mew",
      "properties": {
        "git-mew.llmProvider": {
          "type": "string",
          "enum": [
            "openai",
            "claude",
            "gemini",
            "ollama",
            "custom"
          ],
          "enumDescriptions": [
            "OpenAI GPT models",
            "Anthropic Claude models",
            "Google Gemini models",
            "Ollama local models",
            "Custom OpenAI-compatible endpoint"
          ],
          "description": "Select the LLM provider to use for generating commit messages"
        },
        "git-mew.llmModel.openai": {
          "type": "string",
          "description": "OpenAI model to use"
        },
        "git-mew.llmModel.claude": {
          "type": "string",
          "description": "Claude model to use"
        },
        "git-mew.llmModel.gemini": {
          "type": "string",
          "description": "Gemini model to use"
        },
        "git-mew.llmModel.ollama": {
          "type": "string",
          "description": "Ollama model to use"
        },
        "git-mew.llmModel.custom": {
          "type": "string",
          "description": "Custom provider model to use"
        },
        "git-mew.llmBaseUrl.custom": {
          "type": "string",
          "description": "Base URL for the custom OpenAI-compatible provider. The endpoint must support /chat/completions."
        },
        "git-mew.llmCustomModelContextWindow.openai": {
          "type": "number",
          "default": 128000,
          "description": "Context window used when entering a custom OpenAI model name."
        },
        "git-mew.llmCustomModelMaxOutputTokens.openai": {
          "type": "number",
          "default": 16384,
          "description": "Max output tokens used when entering a custom OpenAI model name."
        },
        "git-mew.llmCustomModelContextWindow.claude": {
          "type": "number",
          "default": 128000,
          "description": "Context window used when entering a custom Claude model name."
        },
        "git-mew.llmCustomModelMaxOutputTokens.claude": {
          "type": "number",
          "default": 16384,
          "description": "Max output tokens used when entering a custom Claude model name."
        },
        "git-mew.llmCustomModelContextWindow.gemini": {
          "type": "number",
          "default": 128000,
          "description": "Context window used when entering a custom Gemini model name."
        },
        "git-mew.llmCustomModelMaxOutputTokens.gemini": {
          "type": "number",
          "default": 16384,
          "description": "Max output tokens used when entering a custom Gemini model name."
        },
        "git-mew.llmCustomModelContextWindow.ollama": {
          "type": "number",
          "default": 128000,
          "description": "Context window used when entering a custom Ollama model name."
        },
        "git-mew.llmCustomModelMaxOutputTokens.ollama": {
          "type": "number",
          "default": 16384,
          "description": "Max output tokens used when entering a custom Ollama model name."
        },
        "git-mew.llmCustomModelContextWindow.custom": {
          "type": "number",
          "default": 128000,
          "description": "Context window used for the custom provider model."
        },
        "git-mew.llmCustomModelMaxOutputTokens.custom": {
          "type": "number",
          "default": 16384,
          "description": "Max output tokens used for the custom provider model."
        },
        "git-mew.commit.contextStrategy": {
          "type": "string",
          "default": "auto",
          "enum": [
            "direct",
            "auto",
            "hierarchical"
          ],
          "description": "Context handling strategy for commit generation"
        },
        "git-mew.reviewMerge.provider": {
          "type": "string",
          "enum": [
            "openai",
            "claude",
            "gemini",
            "ollama",
            "custom"
          ],
          "description": "Last used LLM provider for Review Merge (separate from commit generation)"
        },
        "git-mew.reviewMerge.model": {
          "type": "string",
          "description": "Last used model for Review Merge (separate from commit generation)"
        },
        "git-mew.reviewMerge.language": {
          "type": "string",
          "default": "Vietnamese",
          "enum": [
            "English",
            "Vietnamese",
            "Japanese",
            "Korean",
            "Chinese",
            "French",
            "German",
            "Spanish"
          ],
          "description": "Last used response language for Review Merge"
        },
        "git-mew.reviewMerge.contextStrategy": {
          "type": "string",
          "default": "auto",
          "enum": [
            "direct",
            "auto",
            "hierarchical"
          ],
          "description": "Context handling strategy for Review Merge and Review Staged Changes"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.64.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.4",
    "fast-check": "^4.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sentry/node": "^10.47.0",
    "@types/markdown-it": "^14.1.2",
    "gpt-tokenizer": "^3.4.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-highlightjs": "^4.3.0",
    "plantuml-encoder": "^1.4.0"
  }
}